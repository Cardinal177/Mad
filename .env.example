APP_ENV=development
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cardinal_mad
DB_USER=cardinal_mad
DB_PASS=replace_with_real_password
DEVICE_TOKEN=replace_with_device_token
OTP_TTL_SECONDS=300
SESSION_TTL_HOURS=24

SMS_DRY_RUN=true
INMOBILE_API_URL=https://api.inmobile.com/v4/sms/outgoing
INMOBILE_API_TOKEN=replace_with_inmobile_api_token
INMOBILE_SENDER=MAD

OFF_ENABLED=true
OFF_PRODUCT_URL_TEMPLATE=https://world.openfoodfacts.org/api/v2/product/%s.json
OFF_USER_AGENT='Mad/0.3 (ops@example.com)'
OFF_TIMEOUT_SECONDS=5

FTP_HOST=replace_with_ftp_host
FTP_PORT=21
FTP_USER=replace_with_ftp_user
FTP_PASS=replace_with_ftp_password
FTP_PATH=public_html/mad
FTP_UPLOAD_ENV=false
